{
  "name": "xenblocks-airdrop",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun src/index.ts",
    "status": "bun src/status.ts",
    "release-lock": "bun src/release-lock.ts",
    "mint-proposal": "bun src/mint-proposal.ts",
    "build": "tsc",
    "build:program": "anchor build",
    "start": "bun dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run checks",
    "checks": "bun run lint && bun run format:check && bun run typecheck && bun run test"
  },
  "author": "",
  "license": "ISC",
  "description": "XNM token airdrop script with on-chain tracking and delta calculations",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@ledgerhq/hw-app-solana": "^7.7.0",
    "@ledgerhq/hw-transport-node-hid": "^6.30.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.2",
    "@sqds/multisig": "2.1.3",
    "dotenv": "^17.2.0",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
